---

<section id="editor" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Design visually. Export YAML.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-text-secondary">
        Build your server template in the browser — roles, categories, channels,
        permissions, forums, and emoji — and get back the exact YAML Disco
        Designer applies. Nothing is saved server-side.
      </p>
      <a
        href="/editor"
        class="mt-6 inline-flex items-center gap-2 rounded-xl bg-blurple px-6 py-3 font-semibold text-white shadow-lg shadow-blurple/25 transition-colors hover:bg-blurple-dark"
      >
        Open the Editor
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <img
      src="/editor.jpg"
      alt="Disco Designer template editor showing roles, channels, and a live Discord preview"
      class="w-full rounded-2xl border border-border shadow-2xl shadow-black/20"
      width="1735"
      height="912"
    />
  </div>
</section>
