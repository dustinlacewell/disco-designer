---
const github = "https://github.com/dustinlacewell/disco-designer";
---

<nav class="sticky top-0 z-50 border-b border-border/50 bg-surface/80 backdrop-blur-lg">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-lg font-bold tracking-tight">
      <span class="text-blurple">Disco</span> Designer
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 text-sm text-text-secondary sm:flex">
      <a href="/docs" class="transition-colors hover:text-text-primary">Docs</a>
      <a href="/#features" class="transition-colors hover:text-text-primary">Features</a>
      <a href="/#templates" class="transition-colors hover:text-text-primary">Templates</a>
      <a href="/#getting-started" class="transition-colors hover:text-text-primary">Get Started</a>
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-surface-raised px-3 py-1.5 transition-colors hover:bg-surface-overlay"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        GitHub
      </a>
    </div>

    <!-- Mobile nav -->
    <details class="relative sm:hidden">
      <summary class="cursor-pointer list-none rounded-lg bg-surface-raised p-2 transition-colors hover:bg-surface-overlay">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-2 flex w-48 flex-col gap-1 rounded-xl border border-border bg-surface-raised p-2 shadow-xl">
        <a href="/docs" class="rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-overlay hover:text-text-primary">Docs</a>
        <a href="/#features" class="rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-overlay hover:text-text-primary">Features</a>
        <a href="/#templates" class="rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-overlay hover:text-text-primary">Templates</a>
        <a href="/#getting-started" class="rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-overlay hover:text-text-primary">Get Started</a>
        <a href={github} target="_blank" rel="noopener noreferrer" class="rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-overlay hover:text-text-primary">GitHub</a>
      </div>
    </details>
  </div>
</nav>
