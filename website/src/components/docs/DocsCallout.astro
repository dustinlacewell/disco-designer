---
interface Props {
  type: "warning" | "info" | "danger";
  title?: string;
}

const { type, title } = Astro.props;

const styles = {
  warning: { border: "border-l-yellow-500", bg: "bg-yellow-500/5", icon: "text-yellow-500", iconPath: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" },
  info: { border: "border-l-blurple", bg: "bg-blurple/5", icon: "text-blurple", iconPath: "M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" },
  danger: { border: "border-l-red-500", bg: "bg-red-500/5", icon: "text-red-500", iconPath: "M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" },
};

const s = styles[type];
---

<div class={`mb-6 rounded-r-xl border-l-4 ${s.border} ${s.bg} p-4`}>
  <div class="flex gap-3">
    <svg class={`mt-0.5 h-5 w-5 flex-shrink-0 ${s.icon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={s.iconPath} />
    </svg>
    <div class="docs-prose text-sm">
      {title && <p class="mb-1 font-semibold text-text-primary">{title}</p>}
      <slot />
    </div>
  </div>
</div>
