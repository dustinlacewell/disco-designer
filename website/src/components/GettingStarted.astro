---
const invite = "https://discord.com/oauth2/authorize?client_id=1476885786686263379&permissions=8&integration_type=0&scope=bot+applications.commands";

const steps = [
  {
    number: "1",
    title: "Add the bot to your server",
    description:
      "Invite Disco Designer with Administrator permissions. After adding, drag its role to the top of the role list so it can manage all roles below it.",
    code: null,
    link: { href: invite, label: "Invite Disco Designer" },
  },
  {
    number: "2",
    title: "Write a template — or pick one",
    description:
      "Create a YAML file describing your desired server state, or start with one of the 7 included templates. Define roles, categories, channels, permissions, and emoji.",
    code: `roles:\n  - name: "Admin"\n    color: "#e74c3c"\n    permissions: [Administrator]\n\ncategories:\n  - name: "GENERAL"\n    channels:\n      - name: "general"\n        type: text`,
    link: null,
  },
  {
    number: "3",
    title: "Apply it",
    description:
      "Upload your YAML file with the /apply-template slash command. The bot runs preflight checks, shows you a summary, and asks for confirmation before syncing.",
    code: `/apply-template [template.yaml]`,
    link: null,
  },
];
---

<section id="getting-started" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-3xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Get started in three steps
      </h2>
    </div>

    <div class="relative">
      <!-- Connecting line -->
      <div class="absolute left-5 top-10 bottom-10 hidden w-px bg-border sm:block"></div>

      <div class="space-y-12">
        {steps.map((step) => (
          <div class="flex gap-6">
            <!-- Step number -->
            <div class="relative z-10 hidden sm:block">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blurple font-mono text-sm font-bold text-white shadow-lg shadow-blurple/20">
                {step.number}
              </div>
            </div>

            <!-- Content -->
            <div class="flex-1">
              <div class="flex items-center gap-3 sm:hidden mb-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-blurple font-mono text-xs font-bold text-white">
                  {step.number}
                </div>
                <h3 class="text-lg font-semibold">{step.title}</h3>
              </div>
              <h3 class="hidden sm:block text-lg font-semibold mb-2">{step.title}</h3>
              <p class="text-text-secondary leading-relaxed">{step.description}</p>

              {step.link && (
                <a
                  href={step.link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-2 rounded-lg bg-blurple px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-blurple-dark"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19.27 5.33C17.94 4.71 16.5 4.26 15 4a.09.09 0 00-.07.03c-.18.33-.39.76-.53 1.09a16.09 16.09 0 00-4.8 0c-.14-.34-.35-.76-.54-1.09-.01-.02-.04-.03-.07-.03-1.5.26-2.93.71-4.27 1.33-.01 0-.02.01-.03.02-2.72 4.07-3.47 8.03-3.1 11.95 0 .02.01.04.03.05 1.8 1.32 3.53 2.12 5.24 2.65.02.01.05 0 .07-.02.4-.55.76-1.13 1.07-1.74.02-.04 0-.08-.04-.09-.57-.22-1.11-.48-1.64-.78-.04-.02-.04-.08-.01-.11.11-.08.22-.17.33-.25.02-.02.05-.02.07-.01 3.44 1.57 7.15 1.57 10.55 0 .02-.01.05-.01.07.01.11.09.22.17.33.26.04.03.04.09-.01.11-.52.31-1.07.56-1.64.78-.04.01-.05.06-.04.09.32.61.68 1.19 1.07 1.74.03.01.05.02.07.02 1.72-.53 3.45-1.33 5.24-2.65.02-.01.03-.03.03-.05.44-4.53-.73-8.46-3.1-11.95-.01-.01-.02-.02-.04-.02zM8.52 14.91c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12 0 1.17-.84 2.12-1.89 2.12zm6.97 0c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12 0 1.17-.83 2.12-1.89 2.12z" />
                  </svg>
                  {step.link.label}
                </a>
              )}

              {step.code && (
                <pre class="mt-4 overflow-x-auto rounded-xl border border-border bg-surface-raised p-4 font-mono text-sm leading-relaxed"><code>{step.code}</code></pre>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
