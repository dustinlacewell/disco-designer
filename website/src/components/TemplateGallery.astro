---

<section id="templates" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Start with a template
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-text-secondary">
        7 production-ready templates for the most common server types.
        Use as-is or customize to fit your community.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {templates.map((t) => (
        <a
          href={`/editor?template=${t.file}`}
          class="group rounded-2xl border border-border bg-surface-raised p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-blurple/30 hover:shadow-lg hover:shadow-blurple/5"
        >
          <div class="mb-3 flex items-center gap-3">
            <div
              class="flex h-9 w-9 items-center justify-center rounded-lg"
              style={`background: ${t.color}15; color: ${t.color};`}
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={t.icon} />
              </svg>
            </div>
            <h3 class="font-semibold group-hover:text-blurple-light transition-colors">{t.name}</h3>
          </div>
          <p class="text-sm leading-relaxed text-text-secondary">{t.tagline}</p>
          <div class="mt-3 flex items-center gap-1 text-xs text-text-secondary/60">
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            {t.file}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
