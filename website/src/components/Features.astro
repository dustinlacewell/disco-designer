---
const features = [
  {
    title: "Declarative YAML",
    description:
      "Define roles, channels, categories, permissions, and emoji in a single YAML file. No scripting, no dashboard clicking.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
  },
  {
    title: "Full Sync",
    description:
      "Creates what's missing, updates what's changed, deletes what's extra. One command to match the template exactly.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.356v4.992" />`,
  },
  {
    title: "Preflight Safety",
    description:
      "Before any mutations, preflight checks verify bot permissions, role hierarchy, channel limits, and emoji slots.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
  },
  {
    title: "Every Channel Type",
    description:
      "Text, voice, forum, stage, and announcement channels. Forum tags, slowmode, bitrate, NSFW — all configurable.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5l-3.9 19.5m-2.1-19.5l-3.9 19.5" />`,
  },
  {
    title: "Granular Permissions",
    description:
      "Per-role and per-channel permission overrides with 40+ Discord permission flags. Category inheritance works automatically.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />`,
  },
  {
    title: "Ready-Made Templates",
    description:
      "7 production-ready templates for gaming, dev, creator, SaaS, study, community, and solo-dev Patreon servers.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />`,
  },
];
---

<section id="features" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Everything you need to manage server structure
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-text-secondary">
        Declarative configuration meets Discord's full feature set.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-2xl border border-border bg-surface-raised p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-blurple/30 hover:shadow-lg hover:shadow-blurple/5">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-blurple/10">
            <svg class="h-5 w-5 text-blurple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold">{f.title}</h3>
          <p class="text-sm leading-relaxed text-text-secondary">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
